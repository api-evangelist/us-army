{
  "name": "US Army Article",
  "description": "Structure documentation for US Army news articles from the Army Public API",
  "fields": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Unique article identifier"
    },
    {
      "name": "title",
      "type": "string",
      "required": true,
      "description": "Article headline or title"
    },
    {
      "name": "summary",
      "type": "string (nullable)",
      "required": false,
      "description": "Brief summary or lead paragraph"
    },
    {
      "name": "body",
      "type": "string (nullable)",
      "required": false,
      "description": "Full article body text"
    },
    {
      "name": "author",
      "type": "string (nullable)",
      "required": false,
      "description": "Author or byline"
    },
    {
      "name": "publishedDate",
      "type": "string (date-time)",
      "required": true,
      "description": "ISO 8601 publication date"
    },
    {
      "name": "updatedDate",
      "type": "string (date-time, nullable)",
      "required": false,
      "description": "ISO 8601 last update date"
    },
    {
      "name": "tags",
      "type": "array<string>",
      "required": false,
      "description": "Subject tags for the article"
    },
    {
      "name": "imageUrl",
      "type": "string (uri, nullable)",
      "required": false,
      "description": "Featured image URL"
    },
    {
      "name": "url",
      "type": "string (uri, nullable)",
      "required": false,
      "description": "Canonical URL on army.mil"
    },
    {
      "name": "sourceOrg",
      "type": "string (nullable)",
      "required": false,
      "description": "Publishing Army organization"
    }
  ]
}
